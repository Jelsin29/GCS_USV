/* MODERN USV INDICATORS - TESLA DASHBOARD STYLE */
QWidget {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, 
                               stop:0 #f8f9fa, stop:1 #e9ecef);
    color: #2c3e50;
    font-family: 'Segoe UI', 'San Francisco', Arial, sans-serif;
}

QFrame {
    background: qradial-gradient(cx:0.5, cy:0.5, radius:1.0, 
                                fx:0.5, fy:0.3,
                                stop:0 #ffffff, 
                                stop:0.8 #f8f9fa, 
                                stop:1.0 #e9ecef);
    border: none;
    border-radius: 20px;
    margin: 12px;
    padding: 16px;
}

QLabel {
    background: transparent;
    color: #2c3e50;
    font-weight: 500;
    border: none;
}

/* REMOVE ALL HARSH BORDERS AND LINES */
* {
    border: none;
    outline: none;
}
