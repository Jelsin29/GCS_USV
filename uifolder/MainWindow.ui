  <property name="styleSheet">
   <string notr="true">
/* MODERN WINDOWS 10 LIGHT STYLE */
QMainWindow {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, 
                                stop:0 #f8f9fa, stop:1 #e9ecef);
    color: #212529;
}

/* MODERN TITLE BAR */
QFrame#frame_top {
    background: #ffffff;
    border-bottom: 1px solid #dee2e6;
}

QFrame#frame_top_btns {
    background: #ffffff;
}

/* MODERN BUTTONS - TITLE BAR */
QPushButton#btn_minimize, QPushButton#btn_maximize_restore, QPushButton#btn_close {
    border: none;
    background: transparent;
    padding: 8px;
    color: #495057;
}
QPushButton#btn_minimize:hover, QPushButton#btn_maximize_restore:hover {
    background: #e9ecef;
}
QPushButton#btn_close:hover {
    background: #dc3545;
    color: white;
}

/* MODERN SIDEBAR */
QFrame#frame_left_menu {
    background: #f8f9fa;
    border-right: 1px solid #dee2e6;
}

QPushButton#btn_toggle_menu {
    background: transparent;
    border: none;
    padding: 15px;
    color: #495057;
}
QPushButton#btn_toggle_menu:hover {
    background: #e9ecef;
}

/* MODERN NAVIGATION BUTTONS */
QPushButton#btn_home_page, QPushButton#btn_indicators_page, QPushButton#btn_targets_page {
    background: transparent;
    border: none;
    text-align: left;
    padding: 15px 20px;
    color: #495057;
    font-size: 14px;
    border-left: 3px solid transparent;
}

QPushButton#btn_home_page:hover, QPushButton#btn_indicators_page:hover, QPushButton#btn_targets_page:hover {
    background: #e9ecef;
    color: #212529;
}

QPushButton#btn_home_page:disabled, QPushButton#btn_indicators_page:disabled, QPushButton#btn_targets_page:disabled {
    background: #0d6efd;
    border-left: 3px solid #0d6efd;
    color: #ffffff;
}

/* MODERN CONTENT AREA */
QFrame#frame_content_right {
    background: #ffffff;
}

QFrame#frame_content {
    background: #ffffff;
    border-radius: 8px;
}

/* MODERN CONNECTION CONTROLS */
QComboBox {
    background: #ffffff;
    border: 1px solid #ced4da;
    border-radius: 4px;
    padding: 8px 12px;
    color: #495057;
    selection-background-color: #0d6efd;
}

QComboBox:hover {
    border: 1px solid #0d6efd;
}

QComboBox:focus {
    border: 2px solid #0d6efd;
    outline: none;
}

QComboBox::drop-down {
    border: none;
    width: 20px;
}

QComboBox::down-arrow {
    image: url(uifolder/assets/icons/16x16/cil-arrow-bottom.png);
    width: 12px;
    height: 12px;
}

QComboBox QAbstractItemView {
    background: #ffffff;
    border: 1px solid #ced4da;
    selection-background-color: #0d6efd;
    color: #495057;
}

/* MODERN CONNECT BUTTON */
QPushButton#btn_connect {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, 
                                stop:0 #0d6efd, stop:1 #0b5ed7);
    border: 1px solid #0a58ca;
    border-radius: 4px;
    color: #ffffff;
    font-weight: 600;
    padding: 8px 16px;
}

QPushButton#btn_connect:hover {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, 
                                stop:0 #0b5ed7, stop:1 #0a58ca);
}

QPushButton#btn_connect:pressed {
    background: #0a58ca;
}

/* MODERN SCROLLBARS */
QScrollBar:vertical {
    background: #f8f9fa;
    width: 12px;
    border-radius: 6px;
}

QScrollBar::handle:vertical {
    background: #ced4da;
    border-radius: 6px;
    min-height: 20px;
}

QScrollBar::handle:vertical:hover {
    background: #adb5bd;
}

QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    border: none;
    background: none;
}

/* MODERN STATUS BAR */
QFrame#frame_top_info {
    background: #0d6efd;
    color: #ffffff;
}

/* MODERN GRIP */
QFrame#frame_grip {
    background: #f8f9fa;
}

/* LABELS */
QLabel {
    color: #495057;
}

/* GENERAL BUTTONS */
QPushButton {
    background: #f8f9fa;
    border: 1px solid #ced4da;
    border-radius: 4px;
    padding: 6px 12px;
    color: #495057;
    font-weight: 500;
}

QPushButton:hover {
    background: #e9ecef;
    border-color: #adb5bd;
}

QPushButton:pressed {
    background: #dee2e6;
}

QPushButton:disabled {
    background: #e9ecef;
    color: #6c757d;
    border-color: #dee2e6;
}
