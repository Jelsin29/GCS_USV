  <property name="windowTitle">
   <string>Mission Control</string>
  </property>
  <property name="styleSheet">
   <string notr="true">/* MODERN MISSION CONTROL - LIGHT THEME TESLA STYLE */
QWidget {
    background-color: #f5f5f5;
    color: #2c3e50;
    font-family: 'Segoe UI', 'San Francisco', Arial, sans-serif;
}

/* MAIN FRAMES - CLEAN CARDS WITH SHADOWS */
QFrame {
    background-color: #ffffff;
    border: 1px solid #e9ecef;
    border-radius: 16px;
    margin: 8px;
    padding: 20px;
}

/* SECTION TITLES - MODERN STYLE */
QLabel#missionLabel, QLabel#guidedLabel, QLabel#consoleLabel {
    color: #2c3e50;
    font-size: 18px;
    font-weight: 600;
    background: transparent;
    border: none;
    margin-bottom: 16px;
    padding: 0px;
}

/* MODERN BUTTONS - WITH BORDERS, NO SHADOWS */
QPushButton {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, 
                               stop:0 #f8f9fa, stop:1 #e9ecef);
    border: 2px solid #dee2e6;
    border-radius: 12px;
    padding: 16px 24px;
    color: #495057;
    font-weight: 600;
    font-size: 15px;
    min-height: 24px;
}

QPushButton:hover {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, 
                               stop:0 #e9ecef, stop:1 #dee2e6);
    border-color: #0d6efd;
    color: #0d6efd;

}

QPushButton:pressed {
    background: #dee2e6;
    border-color: #ced4da;

}

/* MODERN COMBO BOX - WITH BORDERS */
QComboBox {
    background: #ffffff;
    border: 2px solid #e9ecef;
    border-radius: 8px;
    padding: 12px 16px;
    color: #495057;
    font-weight: 500;
    font-size: 14px;
}

QComboBox:hover {
    border-color: #0d6efd;
}

QComboBox::drop-down {
    border: none;
    width: 30px;
}

QComboBox::down-arrow {
    image: none;
    border-left: 5px solid transparent;
    border-right: 5px solid transparent;
    border-top: 5px solid #495057;
    margin-right: 10px;
}

QComboBox QAbstractItemView {
    background-color: #ffffff;
    border: 1px solid #e9ecef;
    border-radius: 8px;
    selection-background-color: #0d6efd;
    color: #495057;
}

/* SPECIAL BUTTON COLORS - WITH BORDERS */
QPushButton#btn_antenna {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, 
                               stop:0 #dc3545, stop:1 #c82333);
    border: 2px solid #bd2130;
    color: #495057;
}

QPushButton#btn_antenna:hover {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, 
                               stop:0 #c82333, stop:1 #bd2130);
    border-color: #a71e2a;
}

QPushButton#btn_startMission {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, 
                               stop:0 #28a745, stop:1 #20c997);
    border: 2px solid #1e7e34;
    color: #495057;
}

QPushButton#btn_startMission:hover {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, 
                               stop:0 #20c997, stop:1 #1e7e34);
    border-color: #155724;
}

QPushButton#btn_abort {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, 
                               stop:0 #ffc107, stop:1 #e0a800);
    border: 2px solid #d39e00;
    color: #495057;
}

QPushButton#btn_abort:hover {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, 
                               stop:0 #e0a800, stop:1 #d39e00);
    border-color: #b8860b;
}

/* CONSOLE - DARK TERMINAL STYLE */
QTextBrowser {
    background-color: #212529;
    color: #00ff88;
    border: 1px solid #495057;
    border-radius: 8px;
    font-family: 'Consolas', 'SF Mono', monospace;
    font-size: 12px;
    padding: 16px;
}

/* SECTION BACKGROUNDS - SUBTLE DIFFERENT COLORS WITH BORDERS */
QFrame#missionFrame {
    background-color: #ffffff;
    border: 1px solid #e9ecef;
}

QFrame#guidedFrame {
    background-color: #f8f9fa;
    border: 1px solid #dee2e6;
}

QFrame#consoleFrame {
    background-color: #2d3748;
    border: 1px solid #4a5568;
}

/* CLEAN LABELS */
QLabel {
    color: #2c3e50;
    background: transparent;
    border: none;
}

/* CONSOLE LABEL - WHITE FOR DARK BACKGROUND */
QLabel#consoleLabel {
    color: #ffffff;
}
   </string>
