         <item>
          <widget class="QPushButton" name="btn_antenna">
           <property name="styleSheet">
            <string notr="true">
/* ANTENNA BUTTON - RED STATE (DEFAULT) */
QPushButton#btn_antenna {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, 
                               stop:0 #dc3545, stop:1 #c82333);
    border: 2px solid #bd2130;
    color: #ffffff;
    font-weight: 600;
    font-size: 15px;
    border-radius: 12px;
    padding: 16px 24px;
    min-height: 24px;
}

/* ANTENNA BUTTON - DARKER RED ON HOVER (WHEN NOT ACTIVE) */
QPushButton#btn_antenna:hover {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, 
                               stop:0 #c82333, stop:1 #a71e2a);
    border-color: #a71e2a;
    color: #ffffff;

}

/* ANTENNA BUTTON - PRESSED STATE (MOMENTARY) */
QPushButton#btn_antenna:pressed {
    background: #a71e2a;
    border-color: #921924;

}

/* ANTENNA BUTTON - ACTIVE/TRACKING STATE (GREEN) */
QPushButton#btn_antenna[tracking=&quot;true&quot;] {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, 
                               stop:0 #28a745, stop:1 #1e7e34);
    border: 2px solid #155724;
    color: #ffffff;
}

/* ANTENNA BUTTON - GREEN STATE HOVER (DARKER GREEN) */
QPushButton#btn_antenna[tracking=&quot;true&quot;]:hover {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, 
                               stop:0 #1e7e34, stop:1 #155724);
    border-color: #0f5132;
    color: #ffffff;

}

/* ANTENNA BUTTON - GREEN STATE PRESSED */
QPushButton#btn_antenna[tracking=&quot;true&quot;]:pressed {
    background: #155724;
    border-color: #0f5132;

}</string>
           </property>
           <property name="text">
            <string>ANTENNA TRACKING</string>
           </property>
          </widget>
         </item>
