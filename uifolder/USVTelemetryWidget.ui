  <property name="styleSheet">
   <string notr="true">
/* USV TELEMETRY DASHBOARD - MARITIME THEME */
QWidget {
    background-color: #f8f9fa;
    color: #2c3e50;
    font-family: 'Segoe UI', 'Consolas', monospace;
    font-size: 12px;
}

QFrame {
    background-color: #ffffff;
    border: 2px solid #0d47a1;
    border-radius: 8px;
    margin: 4px;
    padding: 12px;
}

QLabel {
    color: #2c3e50;
    border: none;
    background: transparent;
    font-weight: 500;
}

/* HEADER STYLING */
QLabel#headerLabel {
    color: #ffffff;
    background-color: #0d47a1;
    font-weight: bold;
    font-size: 14px;
    padding: 8px;
    border: none;
    border-radius: 4px;
}

/* SECTION HEADERS */
QLabel#attitudeHeaderLabel, QLabel#systemsHeaderLabel {
    color: #0d47a1;
    font-weight: bold;
    font-size: 13px;
    background: transparent;
    border: none;
    padding: 4px 0px;
}

/* DATA LABELS */
QLabel#statusLabel, QLabel#gpsLabel, QLabel#speedLabel, 
QLabel#headingLabel, QLabel#depthLabel {
    font-family: 'Consolas', monospace;
    font-size: 12px;
    color: #2c3e50;
    background: transparent;
    border: none;
}

/* VALUE LABELS */
QLabel#statusValueLabel {
    color: #ff6b35;
    font-weight: bold;
}

QLabel#gpsValueLabel, QLabel#speedValueLabel, 
QLabel#headingValueLabel, QLabel#depthValueLabel {
    color: #0277bd;
    font-weight: bold;
    font-family: 'Consolas', monospace;
}

/* ATTITUDE VALUES */
QLabel#rollValueLabel, QLabel#pitchValueLabel {
    color: #2e7d32;
    font-weight: bold;
    font-family: 'Consolas', monospace;
}

/* PROGRESS BARS - BATTERY */
QProgressBar#batteryProgressBar {
    border: 2px solid #2e7d32;
    border-radius: 4px;
    background-color: #f5f5f5;
    text-align: center;
    font-weight: bold;
    color: #2c3e50;
    min-height: 20px;
}

QProgressBar#batteryProgressBar::chunk {
    background-color: qlineargradient(x1:0, y1:0, x2:1, y2:0,
                                     stop:0 #4caf50, stop:0.6 #8bc34a, 
                                     stop:1.0 #cddc39);
    border-radius: 2px;
}

/* PROGRESS BARS - RUDDER */
QProgressBar#rudderProgressBar {
    border: 2px solid #ff6b35;
    border-radius: 4px;
    background-color: #f5f5f5;
    text-align: center;
    font-weight: bold;
    color: #2c3e50;
    min-height: 20px;
}

QProgressBar#rudderProgressBar::chunk {
    background-color: qlineargradient(x1:0, y1:0, x2:1, y2:0,
                                     stop:0 #ff9800, stop:0.5 #ff6b35, 
                                     stop:1.0 #f4511e);
    border-radius: 2px;
}
